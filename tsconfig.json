{
  "extends": "./tsconfig.build.json",
  "ts-node": {
    "transpileOnly": true,
    "files": true
  },
  "compilerOptions": {
    "rootDir": ".",
    "outDir": ".tsbuild",
    "declaration": false,
    "esModuleInterop": true,
    "types": ["node", "mocha", "koa-bodyparser"],
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "@types/**/*",
  ],
}
